# Fleetbase Storefront Go SDK - Example Environment Configuration
# Copy this file to .env and fill in your values before running examples

# Required: Your Storefront API key (starts with "store_")
STOREFRONT_KEY=sk_test_your_storefront_key_here

# Optional: Custom API host for testing different environments
FLEETBASE_HOST=https://api.storefront.fleetbase.com/

# Customer Authentication Test - Required variables
CUSTOMER_EMAIL=test@example.com
CUSTOMER_PASSWORD=your_password_here
# CUSTOMER_NAME=Test Customer
